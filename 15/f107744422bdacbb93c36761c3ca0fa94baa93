### Phase 5: Update shell script generators

**File: `src/lib/completions.ts`** — Rewrite the three generators:

#### Bash (`generateBashCompletion`)

```bash
_sentry_completions() {
  local cur prev words cword
  _init_completion || return

  local commands="help auth cli issue org project ..."
  local auth_commands="login logout status refresh whoami"
  # ... (static subcommand lists, same as today)

  # Flag lists per command (new)
  local issue_list_flags="--limit --query --sort --status --cursor --fresh --json --fields"
  local issue_list_sort_values="date priority new freq"
  # ...

  case "${COMP_CWORD}" in
    1) COMPREPLY=($(compgen -W "${commands}" -- "${cur}")) ;;
    2)
      case "${prev}" in
        auth) COMPREPLY=($(compgen -W "${auth_commands}" -- "${cur}")) ;;
        # ...
      esac ;;
    *)
      # Determine command path
      local cmd="${COMP_WORDS[1]}"
      local subcmd="${COMP_WORDS[2]}"

      if [[ "${cur}" == --* ]]; then
        # Flag name completion (static)
        local flagvar="${cmd}_${subcmd}_flags"
        COMPREPLY=($(compgen -W "${!flagvar}" -- "${cur}"))
      elif [[ "${prev}" == --sort || "${prev}" == --status ]]; then
        # Enum value completion (static)
        local valvar="${cmd}_${subcmd}_${prev#--}_values"
        COMPREPLY=($(compgen -W "${!valvar}" -- "${cur}"))
      else
        # Dynamic value completion (from cache, with fuzzy matching)
        # NOTE: Do NOT use `compgen -W ... -- "${cur}"` here — that does
        # prefix filtering which would discard fuzzy matches. The binary
        # already returns only relevant matches (prefix + fuzzy).
        local IFS=$'\n'
        COMPREPLY=($(sentry __complete "${COMP_WORDS[@]:1}" 2>/dev/null))
        # Strip tab-separated descriptions (bash doesn't support them)
        COMPREPLY=($(printf '%s\n' "${COMPREPLY[@]}" | cut -f1))
      fi
      ;;
  esac
}
complete -F _sentry_completions sentry
```

