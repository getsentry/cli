  needs: [changes, build-binary, generate-patches]
  runs-on: ubuntu-latest
  steps:
    - name: Download compressed artifacts
      uses: actions/download-artifact@v8
      with:
        pattern: sentry-*-gz
        path: artifacts
        merge-multiple: true

    - name: Download uncompressed artifacts (for SHA-256 computation)
      uses: actions/download-artifact@v8
      with:
