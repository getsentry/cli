## Implementation Details

### Argument disambiguation (core logic)
```typescript
type ParsedSpanListArgs =
  | { mode: "project"; target?: string }
  | { mode: "trace"; parsed: ParsedTraceTarget };

export function parseSpanListArgs(args: string[]): ParsedSpanListArgs {
  if (args.length === 0) return { mode: "project" };

  // Two+ args: check if last arg is a trace ID (space-separated form)
  if (args.length >= 2) {
    const last = args.at(-1);
    if (last && isTraceId(last)) {
      return { mode: "trace", parsed: parseTraceTarget(args, TRACE_USAGE_HINT) };
    }
  }

  // Single arg: check tail segment after last "/"
  const first = args[0]!;
  const segments = first.split("/");
  const tail = segments.at(-1) ?? first;
  if (isTraceId(tail)) {
    return { mode: "trace", parsed: parseTraceTarget(args, TRACE_USAGE_HINT) };
  }

  // Not a trace ID → project target
  return { mode: "project", target: first };
}
```

### func() handler (simplified)
```typescript
async *func(this: SentryContext, flags: ListFlags, ...args: string[]) {
  const parsed = parseSpanListArgs(args);

  if (parsed.mode === "trace") {
    // Existing trace-scoped behavior
    const { traceId, org, project } = await resolveTraceOrgProject(parsed.parsed, cwd, TRACE_USAGE_HINT);
    const query = `trace:${traceId}${flags.query ? ` ${translateSpanQuery(flags.query)}` : ""}`;
    const { data, nextCursor } = await listSpans(org, project, {
      query, sort, limit, cursor, statsPeriod: flags.period,
    });
    // ... output with "Spans in trace `{traceId}`:" header
  } else {
    // New project-wide mode
    const { org, project } = await resolveOrgProjectFromArg(parsed.target, cwd, "span list");
    const query = flags.query ? translateSpanQuery(flags.query) : undefined;
    const { data, nextCursor } = await listSpans(org, project, {
      query, sort, limit, cursor, statsPeriod: flags.period,
    });
    // ... output with "Spans in {org}/{project}:" header
  }
}
```

### Pagination keys
- Trace mode: `buildPaginationContextKey("span", "${org}/${project}/${traceId}", { sort, q, period })`
- Project mode: `buildPaginationContextKey("span-search", "${org}/${project}", { sort, q, period })`

### Updated help text
```
List spans from a Sentry project, or within a specific trace.

Target patterns (project mode):
  sentry span list                        # auto-detect from DSN or config
  sentry span list <org>/<project>        # explicit org and project
  sentry span list <project>              # find project across all orgs

Trace mode (provide a 32-char trace ID):
  sentry span list <trace-id>             # auto-detect org/project
  sentry span list <org>/<project>/<trace-id>  # explicit

Examples:
  sentry span list                        # List recent spans in project
  sentry span list -q "op:db"             # Find all DB spans
  sentry span list -q "duration:>100ms"   # Slow spans
  sentry span list --period 24h           # Last 24 hours
  sentry span list <trace-id>             # Spans in a specific trace
  sentry span list <trace-id> -q "op:db"  # DB spans in a trace
```

