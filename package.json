{
  "name": "toolkit-cli-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.15"
  },
  "scripts": {
    "tsx": "pnpm --filter sentry run tsx",
    "cli": "pnpm --filter sentry run cli",
    "dev": "pnpm --filter sentry run dev",
    "build": "pnpm --filter sentry run build",
    "build:all": "pnpm --filter sentry run build:all",
    "bundle": "pnpm --filter sentry run bundle",
    "typecheck": "pnpm --filter sentry run typecheck",
    "lint": "pnpm --filter sentry run lint",
    "lint:fix": "pnpm --filter sentry run lint:fix",
    "test": "pnpm --filter sentry run test",
    "test:unit": "pnpm --filter sentry run test:unit",
    "test:changed": "pnpm --filter sentry run test:changed",
    "test:e2e": "pnpm --filter sentry run test:e2e",
    "test:init-eval": "pnpm --filter sentry run test:init-eval",
    "generate:parser": "pnpm --filter sentry run generate:parser",
    "generate:sdk": "pnpm --filter sentry run generate:sdk",
    "generate:skill": "pnpm --filter sentry run generate:skill",
    "generate:banner": "pnpm --filter sentry run generate:banner",
    "generate:docs": "pnpm --filter sentry run generate:docs",
    "generate:docs-sections": "pnpm --filter sentry run generate:docs-sections",
    "generate:schema": "pnpm --filter sentry run generate:schema",
    "generate:command-docs": "pnpm --filter sentry run generate:command-docs",
    "eval:skill": "pnpm --filter sentry run eval:skill",
    "bench": "pnpm --filter sentry run bench",
    "bench:save": "pnpm --filter sentry run bench:save",
    "bench:compare": "pnpm --filter sentry run bench:compare",
    "bench:sweep": "pnpm --filter sentry run bench:sweep",
    "check:fragments": "pnpm --filter sentry run check:fragments",
    "check:deps": "pnpm --filter sentry run check:deps",
    "check:errors": "pnpm --filter sentry run check:errors",
    "check:patches": "pnpm --filter sentry run check:patches",
    "check:docs-sections": "pnpm --filter sentry run check:docs-sections",
    "check:stale-refs": "pnpm --filter sentry run check:stale-refs"
  },
  "pnpm": {
    "patchedDependencies": {
      "@stricli/core@1.2.8": "packages/cli/patches/@stricli%2Fcore@1.2.8.patch",
      "@sentry/node-core@10.63.0": "packages/cli/patches/@sentry%2Fnode-core@10.63.0.patch",
      "@sentry/core@10.63.0": "packages/cli/patches/@sentry%2Fcore@10.63.0.patch"
    },
    "overrides": {
      "esbuild@>=0.17.0 <0.28.1": "0.28.1",
      "js-yaml@<3.15.0": "3.15.0",
      "shell-quote@<1.8.4": "1.8.4",
      "qs@>=6.11.1 <=6.15.1": "6.15.2",
      "form-data@<4.0.6": "4.0.6",
      "vite": "8.0.16",
      "js-yaml@4.1.1": "4.2.0",
      "@babel/core@<7.29.6": "7.29.6"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
