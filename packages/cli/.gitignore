# Package-level ignores (see the workspace-root .gitignore for shared rules).
# Duplicated here because Biome resolves useIgnoreFile relative to biome.jsonc.

# dependencies
node_modules

# build output
out
dist
dist-bin
dist-build
*.tgz

# fossilize build cache
.node-cache

# code coverage
coverage
coverage-isolated
*.lcov

# test artifacts
*.junit.xml
test/skill-eval/results.json

# local bench baselines
.bench/

# caches
*.tsbuildinfo

# generated files (rebuilt at build time)
src/generated/
src/sdk.generated.ts
src/sdk.generated.d.cts
!src/generated/banner-sixel.ts
