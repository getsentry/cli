## 4. Library Entry Point — `src/index.ts` (NEW)

```typescript
import { getEnv, setEnv } from "./lib/env.js";
import type { Writer } from "./types/index.js";

export interface SentryOptions {
  /** Auth token. Auto-filled from SENTRY_AUTH_TOKEN / SENTRY_TOKEN env vars. */
  token?: string;
  /** Return human-readable text instead of parsed JSON. */
  text?: boolean;
  /** Working directory (affects DSN detection, project root). Defaults to process.cwd(). */
  cwd?: string;
}

export class SentryError extends Error {
  exitCode: number;
  stderr: string;

  constructor(message: string, exitCode: number, stderr: string) {
    super(message);
    this.name = "SentryError";
    this.exitCode = exitCode;
    this.stderr = stderr;
  }
}

function sentry(...input: string[]): Promise<unknown>;
function sentry(...input: [...string[], SentryOptions]): Promise<unknown>;
async function sentry(...input: (string | SentryOptions)[]): Promise<unknown> {
  // Detect trailing options object
  let args: string[];
  let options: SentryOptions | undefined;
  const last = input[input.length - 1];
  if (typeof last === "object" && last !== null) {
    options = last as SentryOptions;
    args = input.slice(0, -1) as string[];
  } else {
    args = input as string[];
  }

  // Build isolated env — inherits consumer's process.env, never mutates it
  const env: NodeJS.ProcessEnv = { ...process.env };
  if (options?.token) {
    env.SENTRY_AUTH_TOKEN = options.token;
  }
  if (!options?.text) {
    env.SENTRY_OUTPUT_FORMAT = "json";
  }

  const cwd = options?.cwd ?? process.cwd();

  setEnv(env);

  try {
    // Capture output
    const stdoutChunks: string[] = [];
    const stderrChunks: string[] = [];
    let capturedResult: unknown;
    const stdout: Writer & { captureObject?: (obj: unknown) => void } = {
      write: (s) => { stdoutChunks.push(s); },
      captureObject: (obj) => { capturedResult = obj; }, // zero-copy from renderCommandOutput
    };
    const stderr: Writer = { write: (s) => { stderrChunks.push(s); } };

    const fakeProcess = {
      stdout, stderr,
      stdin: process.stdin,
      env,
      cwd: () => cwd,
      exitCode: 0,
    };

    // Dynamic imports — heavy deps only load on first call
    const { run } = await import("@stricli/core");
    const { app } = await import("./app.js");
    const { buildContext } = await import("./context.js");
    const { withTelemetry } = await import("./lib/telemetry.js");

    await withTelemetry(
      async (span) => run(app, args, buildContext(fakeProcess as any, span)),
      { libraryMode: true },
    );

    // Flush telemetry (no beforeExit handler in library mode)
    try {
      const Sentry = await import("@sentry/node-core/light");
      const client = Sentry.getClient();
      if (client) await client.flush(3000);
    } catch { /* non-critical */ }

    const stderrStr = stderrChunks.join("");
    const stdoutStr = stdoutChunks.join("");

    // Non-zero exit → throw
    if (fakeProcess.exitCode !== 0) {
      const message = stderrStr.replace(/\x1b\[[0-9;]*m/g, "").trim()
        || `Command failed with exit code ${fakeProcess.exitCode}`;
      throw new SentryError(message, fakeProcess.exitCode, stderrStr);
    }

    // Return captured object (zero-copy) or fall back to stdout parsing
    if (capturedResult !== undefined) return capturedResult;
    if (!stdoutStr.trim()) return undefined;
    try {
      return JSON.parse(stdoutStr);
    } catch {
      return stdoutStr.trim();
    }
  } finally {
    setEnv(process.env);
  }
}

export { sentry };
export default sentry;

// CLI runner — internal, used by dist/bin.cjs wrapper
export { startCli as _cli } from "./cli.js";
```

**Key behaviors:**
- **Env isolation**: Builds `{ ...process.env }` copy, sets `token` and `SENTRY_OUTPUT_FORMAT` on it. Consumer's `process.env` is never mutated.
- **Token auto-fill**: If `token` option is not provided, `SENTRY_AUTH_TOKEN` / `SENTRY_TOKEN` from the consumer's `process.env` carry through automatically (they're in the copied env). Explicit `token` option overrides.
- **Variadic args**: Last-arg object detection. `sentry("issue", "list")` and `sentry("issue", "list", { token: "..." })` both work.
- **JSON by default**: `SENTRY_OUTPUT_FORMAT=json` set unless `text: true`.
- **Zero-copy return**: Data commands return the in-memory object directly via `captureObject` on the Writer — no `JSON.stringify` → `JSON.parse` round-trip. Falls back to stdout parsing for non-JSON commands (help, --version).
- **Error as exception**: Non-zero exit → `SentryError` with cleaned message and raw stderr.
- **Successful stderr discarded**: Hints/tips are irrelevant for library consumers.
- **Dynamic imports**: Same pattern as `bin.ts` — `import sentry from "sentry"` is fast; heavy deps load on first invocation.

