```typescript
import { startCli } from "./cli.js";

// Stream error handlers — CLI-specific (library uses captured Writers)
function handleStreamError(err: NodeJS.ErrnoException): void {
  if (err.code === "EPIPE") process.exit(0);
  if (err.code === "EIO") process.exit(1);
  throw err;
}
process.stdout.on("error", handleStreamError);
process.stderr.on("error", handleStreamError);

startCli().catch(() => {});
```

Only used by `bun compile` pipeline. The npm path goes through `dist/bin.cjs` → `_cli()`.

