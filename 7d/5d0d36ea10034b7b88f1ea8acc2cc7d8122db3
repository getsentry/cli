# Plan: Tier 1 Library Export

## Consumer API

```typescript
import sentry from "sentry";

// Variadic args — just like typing the CLI command
const issues = await sentry("issue", "list", "-l", "5");
// → { data: [...], hasMore: true, nextCursor: "..." }

// Explicit auth token (optional — auto-fills from SENTRY_AUTH_TOKEN env var)
const orgs = await sentry("org", "list", { token: "sntrys_..." });

// Custom working directory (for DSN detection, project root)
const issues = await sentry("issue", "list", { cwd: "/path/to/project" });

// Text output (human-readable string instead of parsed JSON)
const text = await sentry("issue", "list", { text: true });
// → "ID       TITLE         STATUS\n..."

// Commands without JSON support return trimmed string
const version = await sentry("--version");
// → "sentry 0.21.0"

// Errors are thrown
try {
  await sentry("issue", "view", "NONEXISTENT-1");
} catch (err) {
  // err instanceof SentryError
  // err.exitCode === 1
  // err.stderr === "Error: Issue not found..."
}
```

