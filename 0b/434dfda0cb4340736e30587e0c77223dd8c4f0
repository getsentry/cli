### 1b. Update `resolveDashboardId()` — `src/commands/dashboard/resolve.ts`

Currently calls `listDashboards()` to fetch all dashboards and do a title search. Replace with paginated search that stops early on match, and use `fuzzyMatch()` from `src/lib/fuzzy.ts` for error suggestions:

```typescript
import { fuzzyMatch } from "../../lib/fuzzy.js";

export async function resolveDashboardId(orgSlug: string, ref: string): Promise<string> {
  if (isAllDigits(ref)) return ref;

  const lowerRef = ref.toLowerCase();
  const allTitles: string[] = [];
  const titleToId = new Map<string, string>();
  let cursor: string | undefined;

  for (let page = 0; page < MAX_PAGINATION_PAGES; page++) {
    const { data, nextCursor } = await listDashboardsPaginated(orgSlug, {
      perPage: API_MAX_PER_PAGE, cursor,
    });
    const match = data.find(d => d.title.toLowerCase() === lowerRef);
    if (match) return match.id;

    for (const d of data) {
      allTitles.push(d.title);
      titleToId.set(d.title, d.id);
    }
    if (!nextCursor) break;
    cursor = nextCursor;
  }

  // No match — use fuzzy search for suggestions
  const similar = fuzzyMatch(ref, allTitles, { maxResults: 5 });
  const suggestions = similar.map(t => `  ${titleToId.get(t)}  ${t}`).join("\n");
  const hint = similar.length > 0
    ? `\n\nDid you mean:\n${suggestions}`
    : allTitles.length > 0
      ? `\n\nThe org has ${allTitles.length} dashboard(s) but none matched.`
      : "\n\nNo dashboards found in this organization.";

  throw new ValidationError(
    `No dashboard with title '${ref}' found in '${orgSlug}'.${hint}`
  );
}
```

Finds the match as early as possible (often page 1). Only fetches all pages when there's no match (to build fuzzy suggestions). Uses existing `fuzzyMatch()` which ranks by exact → prefix → substring → Levenshtein distance.

