export function isTelemetryEnabled(): boolean {
  if (getEnv().SENTRY_CLI_NO_TELEMETRY === "1") return false;
  if (getEnv().DO_NOT_TRACK === "1") return false;
  try {
    const pref = getTelemetryPreference();  // from db/defaults.ts
    if (pref !== undefined) return pref;
  } catch { /* DB not ready */ }
  return true;
}
```

