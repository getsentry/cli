### 6. `src/lib/db/schema.ts` ŌĆö Drop defaults table + migration

- Remove `defaults` entry from `TABLE_SCHEMAS` (lines 71-82)
- Bump `CURRENT_SCHEMA_VERSION` from 12 to 13
- Add migration 12ŌåÆ13 in `runMigrations()`:

```typescript
// Migration 12 -> 13: Consolidate defaults into metadata KV table.
if (currentVersion < 13) {
  if (tableExists(db, "defaults")) {
    const row = db.query("SELECT organization, project FROM defaults WHERE id = 1")
      .get() as { organization: string | null; project: string | null } | null;
    if (row?.organization) {
      db.query("INSERT OR REPLACE INTO metadata (key, value) VALUES (?, ?)")
        .run("defaults.org", row.organization);
    }
    if (row?.project) {
      db.query("INSERT OR REPLACE INTO metadata (key, value) VALUES (?, ?)")
        .run("defaults.project", row.project);
    }
    db.exec("DROP TABLE defaults");
  }
}
```

