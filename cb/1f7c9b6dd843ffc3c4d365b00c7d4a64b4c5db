function matchSharePath(
  baseUrl: string,
  segments: string[]
): ParsedSentryUrl | null {
  if (segments[0] !== "share" || segments[1] !== "issue" || !segments[2]) {
    return null;
  }
  return { baseUrl, shareId: segments[2] };
}
