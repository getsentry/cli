### 3. `src/lib/api/issues.ts` — Share API function

Add `getSharedIssue()` that calls `GET /api/0/shared/issues/{shareId}/`:

```typescript
export async function getSharedIssue(
  baseUrl: string,
  shareId: string
): Promise<{ groupID: string }> {
  const url = `${baseUrl}/api/0/shared/issues/${encodeURIComponent(shareId)}/`;
  const response = await fetch(url, {
    headers: { "Content-Type": "application/json" },
  });
  if (!response.ok) {
    if (response.status === 404) {
      throw new ApiError(
        "Share link not found or expired",
        404,
        "The share link may have been disabled by the issue owner.\n" +
          "  Ask them to re-enable sharing, or use the issue ID directly.",
        `shared/issues/${shareId}`
      );
    }
    throw new ApiError(
      `Failed to resolve share link`,
      response.status,
      undefined,
      `shared/issues/${shareId}`
    );
  }
  return (await response.json()) as { groupID: string };
}
```

Key design decisions:
- Uses raw `fetch` (not `apiRequestToRegion`) because the share endpoint is public/unauthenticated
- `baseUrl` comes from the share URL itself — no region resolution needed
- Only extracts `groupID` — full details come from the authenticated API

**Re-export from `src/lib/api-client.ts`** — add `getSharedIssue` to the issues export block.

### 4. `src/commands/issue/utils.ts` — Handle `"share"` type

**Add `resolveShareIssue()` function**:
```typescript
async function resolveShareIssue(
  shareId: string,
  org: string | undefined,
  baseUrl: string,
  cwd: string,
  command: string,
  commandBase: string
): Promise<ResolvedIssueResult> {
  const shared = await getSharedIssue(baseUrl, shareId);
  const groupId = shared.groupID;

  // Fetch full issue via authenticated API
  if (org) {
    const resolvedOrg = await resolveEffectiveOrg(org);
    const issue = await getIssueInOrg(resolvedOrg, groupId, {
      collapse: ISSUE_DETAIL_COLLAPSE,
    });
    return { org: resolvedOrg, issue };
  }

  // No org from URL — fall back to unscoped fetch + permalink extraction
  const resolvedOrg = await resolveOrg({ cwd });
  const issue = resolvedOrg
    ? await getIssueInOrg(resolvedOrg.org, groupId, { collapse: ISSUE_DETAIL_COLLAPSE })
    : await getIssue(groupId, { collapse: ISSUE_DETAIL_COLLAPSE });
  return {
    org: resolvedOrg?.org ?? extractOrgFromPermalink(issue.permalink),
    issue,
  };
}
```

**Add `"share"` case to `resolveIssue()` switch** (before `default`):
