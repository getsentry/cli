/** Span count threshold for the large-trace informational warning */
const LARGE_TRACE_WARN_THRESHOLD = 500;

/** Span count threshold for showing progress indicator */
const PROGRESS_THRESHOLD = 20;

/**
 * Flatten nested span tree into an array in depth-first order.
 * Collects ALL spans — no cap.
 * @internal Exported for testing
 */
export function flattenSpanTree(spans: TraceSpan[]): TraceSpan[];

/**
 * Recursively merge detail data dicts onto a span tree for JSON output.
 * Each span with a matching detail entry gets a `data` dict.
 */
function mergeSpanDetails(
  span: TraceSpan,
  details: Map<string, TraceItemDetail>
): TraceSpan & { data?: Record<string, unknown> };
```

**In `func()`** — after fetching spans and computing summary, before yield:
```typescript
// Determine whether to fetch per-span details:
// - Explicitly via --full flag
// - Automatically when --json is set (issue #736)
const shouldFetchDetails = flags.full || flags.json;

let spanDetails: Map<string, TraceItemDetail> | undefined;
if (shouldFetchDetails) {
  const flat = flattenSpanTree(spans);
  if (flat.length > LARGE_TRACE_WARN_THRESHOLD) {
    log.warn(
      `Trace has ${flat.length} spans — this may take a moment. ` +
      `Use 'sentry span view' for specific spans.`
    );
  }
  spanDetails = await fetchMultiSpanDetails(
    flat, org, project, traceId,
    {
      onProgress: flat.length > PROGRESS_THRESHOLD
        ? (done, total) => log.info(`Fetching span data (${done}/${total})...`)
        : undefined,
    }
  );
}

yield new CommandOutput({ summary, spans, spanTreeLines, details: spanDetails });
```

Note: `trace view` currently only captures `org` (not `project`) in the normal
path. We need to also capture `resolved.project` from `resolveTraceOrgProject()`.
In the `issueShortId` path, use `issue.project?.slug`.

**Update `jsonTransformTraceView`:**
```typescript
function jsonTransformTraceView(data: TraceViewData, fields?: string[]): unknown {
  const { summary, spans, details } = data;
  const cleanedSpans = (spans as TraceSpan[]).map((span) => {
    const cleaned = filterSpanMeasurements(span);
    return details ? mergeSpanDetails(cleaned, details) : cleaned;
  });
  const result: Record<string, unknown> = { ...summary, spans: cleanedSpans };
  if (fields && fields.length > 0) {
    return filterFields(result, fields);
  }
  return result;
}
```

