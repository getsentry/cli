/** Concurrency for parallel detail fetches (shared between trace/span view) */
export const SPAN_DETAIL_CONCURRENCY = 15;

/**
 * Convert trace-items attribute array to a key-value dict,
 * filtering redundant/internal attributes.
 */
export function attributesToDict(
  attributes: TraceItemDetail["attributes"]
): Record<string, unknown>;

/**
 * Fetch full attribute details for multiple spans in parallel.
 * Uses p-limit for concurrency control. Individual failures are logged
 * as warnings — returns a partial map.
 *
 * @param onProgress - Optional callback fired after each successful fetch
 */
export async function fetchMultiSpanDetails(
  spans: Array<{ span_id: string; project_slug?: string }>,
  org: string,
  fallbackProject: string,
  traceId: string,
  options?: { onProgress?: (done: number, total: number) => void }
): Promise<Map<string, TraceItemDetail>>;
```

Import `p-limit` here (already a devDependency).

