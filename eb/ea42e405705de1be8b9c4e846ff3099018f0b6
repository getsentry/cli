## Implementation Plan

### 1. Add Types — `src/types/sentry.ts`

Add Zod schemas and types for product trial data:

```typescript
/** A single product trial entry from the customer endpoint */
export const ProductTrialSchema = z.object({
  category: z.string(),
  isStarted: z.boolean(),
  lengthDays: z.number().nullable(),
  startDate: z.string().nullable(),
  endDate: z.string().nullable(),
  reasonCode: z.number(),
});
export type ProductTrial = z.infer<typeof ProductTrialSchema>;

/** Partial customer response — only the fields we need */
export const CustomerTrialInfoSchema = z.object({
  productTrials: z.array(ProductTrialSchema).optional(),
});
export type CustomerTrialInfo = z.infer<typeof CustomerTrialInfoSchema>;
```

Re-export from `src/types/index.ts`.

### 2. Add API Functions — `src/lib/api-client.ts`

Two new functions using `apiRequestToRegion`:

```typescript
/**
 * Fetch available Seer product trials for an organization.
 * Returns the matching unstarted trial if one exists, null otherwise.
 */
export async function getSeerTrialStatus(
  orgSlug: string
): Promise<ProductTrial | null> {
  const regionUrl = await resolveOrgRegion(orgSlug);
  const { data } = await apiRequestToRegion<CustomerTrialInfo>(
    regionUrl,
    `/customers/${orgSlug}/`,
    { schema: CustomerTrialInfoSchema }
  );
  const trials = data.productTrials ?? [];
  // Prefer seat-based seerUsers, fall back to legacy seerAutofix
  return (
    trials.find((t) => !t.isStarted && t.category === "seerUsers") ??
    trials.find((t) => !t.isStarted && t.category === "seerAutofix") ??
    null
  );
}

/**
 * Start a Seer product trial for an organization.
 * @param orgSlug - Organization slug
 * @param category - Trial category (from getSeerTrialStatus result)
 */
export async function startSeerTrial(
  orgSlug: string,
  category: string
): Promise<void> {
  const regionUrl = await resolveOrgRegion(orgSlug);
  await apiRequestToRegion(
    regionUrl,
    `/customers/${orgSlug}/product-trial/`,
    {
      method: "PUT",
      body: {
        referrer: "sentry-cli",
        productTrial: { category, reasonCode: 0 },
      },
    }
  );
}
```

### 3. Create Trial Prompt Module — `src/lib/seer-trial.ts`

New module handling the trial check + interactive prompt + trial activation:

```typescript
/**
 * Seer Trial Prompt
 *
 * Checks if an organization has an available Seer product trial
 * and interactively prompts the user to start it.
 */

import { isatty } from "node:tty";
import { SeerError } from "./errors.js";
import { getSeerTrialStatus, startSeerTrial } from "./api-client.js";
import { success, muted } from "./formatters/colors.js";
import log from "./logger.js";

/** Reasons that could be resolved by starting a trial */
const TRIAL_ELIGIBLE_REASONS: Set<string> = new Set(["no_budget", "not_enabled"]);

/**
 * Check if a SeerError could potentially be resolved by a product trial.
 *
 * Returns false for:
 * - Non-SeerError errors
 * - ai_disabled (admin choice, not a plan issue)
 * - Missing orgSlug (can't check trial status)
 * - Non-interactive terminals
 */
export function isTrialEligibleError(err: unknown): err is SeerError & { orgSlug: string } {
  return (
    err instanceof SeerError &&
    TRIAL_ELIGIBLE_REASONS.has(err.reason) &&
    err.orgSlug !== undefined &&
    isatty(0)
  );
}

/**
 * Attempt to offer and start a Seer trial for the user.
 *
 * Flow:
 * 1. Check if org has an available (unstarted) Seer trial
 * 2. If yes, prompt user to start it
 * 3. If user confirms, start the trial via API
 * 4. Return true if trial was started (caller should retry command)
 *
 * Returns false (and falls through to normal error) if:
 * - No trial available
 * - User declines
 * - API call fails (degrades gracefully)
 *
 * @param orgSlug - Organization slug (must be defined)
 * @param stderr - Writer for user messages
 * @returns true if trial was started successfully
 */
export async function promptAndStartSeerTrial(
  orgSlug: string,
  stderr: NodeJS.WritableStream,
): Promise<boolean> {
  // Step 1: Check trial availability (may fail — degrade gracefully)
  let trial: Awaited<ReturnType<typeof getSeerTrialStatus>>;
  try {
    trial = await getSeerTrialStatus(orgSlug);
  } catch {
    // Can't check trial status (network error, permissions, etc.)
    // Fall through to normal error display
    return false;
  }

  if (!trial) {
    // No trial available — fall through to normal error
    return false;
  }

  // Step 2: Prompt user
  const daysText = trial.lengthDays ? `${trial.lengthDays}-day` : "";
  stderr.write(
    `\nA free ${daysText} Seer trial is available for your organization.\n`
  );

  const confirmed = await log.prompt(
    "Would you like to start your free Seer trial?",
    { type: "confirm", initial: true }
  );

  // Symbol(clack:cancel) on Ctrl+C is truthy — use strict equality
  if (confirmed !== true) {
    return false;
  }

  // Step 3: Start the trial
  try {
    await startSeerTrial(orgSlug, trial.category);
  } catch (err) {
    log.warn("Failed to start trial. Please try again or visit your billing settings.");
    return false;
  }

  stderr.write(`\n${success("✓")} Seer trial started! Retrying command...\n\n`);
  return true;
}
```

### 4. Add Trial Middleware to `bin.ts`

Add a `executeWithSeerTrial` wrapper between `executeWithAutoAuth` and `runCommand`, following the same pattern as the auth auto-login:

```typescript
import { SeerError } from "./lib/errors.js";
import { isTrialEligibleError, promptAndStartSeerTrial } from "./lib/seer-trial.js";

/**
 * Execute command with automatic Seer trial prompt.
 *
 * If a Seer command fails with no_budget or not_enabled, check for available
 * trials and prompt the user to start one, then retry the command.
 */
async function executeWithSeerTrial(args: string[]): Promise<void> {
  try {
    await runCommand(args);
  } catch (err) {
    if (isTrialEligibleError(err)) {
      const trialStarted = await promptAndStartSeerTrial(
        err.orgSlug,
        process.stderr,
      );
      if (trialStarted) {
        await runCommand(args);
        return;
      }
    }
    throw err;
  }
}
```

Then update `executeWithAutoAuth` to call `executeWithSeerTrial` instead of `runCommand` directly:

```typescript
async function executeWithAutoAuth(args: string[]): Promise<void> {
  try {
    await executeWithSeerTrial(args);  // was: runCommand(args)
  } catch (err) {
    if (/* auth error check */) {
      // ... existing auth flow ...
      if (loginSuccess) {
        process.stderr.write("\nRetrying command...\n\n");
        await executeWithSeerTrial(args);  // was: runCommand(args)
        return;
      }
      // ...
    }
    throw err;
  }
}
```

**Layering**: `main() → executeWithAutoAuth() → executeWithSeerTrial() → runCommand()`

This ensures:
- Auth errors from the trial API calls themselves bubble up to the auth layer
- Seer errors are caught before generic error display
- The retry after auth login also goes through the Seer trial wrapper

