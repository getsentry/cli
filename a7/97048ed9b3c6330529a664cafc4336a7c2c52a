## Step 2: `src/lib/binary.ts` — Runtime musl detection

1. **Add `isMusl()` function** (cached, sync):
   ```typescript
   let cachedIsMusl: boolean | undefined;

   function isMusl(): boolean {
     if (process.platform !== "linux") return false;
     if (cachedIsMusl !== undefined) return cachedIsMusl;

     // Check for musl dynamic linker (fast stat, works on all musl distros)
     const muslArch = process.arch === "x64" ? "x86_64" : "aarch64";
     if (existsSync(`/lib/ld-musl-${muslArch}.so.1`)) {
       cachedIsMusl = true;
       return true;
     }

     // Fallback: ldd --version (musl ldd writes "musl libc" to stderr)
     try {
       const result = Bun.spawnSync(["ldd", "--version"], {
         stdout: "pipe",
         stderr: "pipe",
       });
       const output =
         Buffer.from(result.stdout).toString() +
         Buffer.from(result.stderr).toString();
       cachedIsMusl = output.toLowerCase().includes("musl");
       return cachedIsMusl;
     } catch {
       cachedIsMusl = false;
       return false;
     }
   }
   ```

   - `existsSync` is already imported. `Bun.spawnSync` is polyfilled in Node.js distribution.
   - Cached because libc can't change at runtime.

2. **Update `getPlatformBinaryName()`** — insert musl suffix:
   ```typescript
   export function getPlatformBinaryName(): string {
     // ... existing os/arch logic ...
     const libcSuffix = isMusl() ? "-musl" : "";
     const suffix = process.platform === "win32" ? ".exe" : "";
     return `sentry-${os}-${arch}${libcSuffix}${suffix}`;
   }
   ```

   This auto-propagates to `getBinaryDownloadUrl()`, `upgrade.ts`, and `delta-upgrade.ts`.

