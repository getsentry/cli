### 2. `trace view` — Use resolved project

**File: `src/commands/trace/view.ts`**

Currently discards `resolved.project`. Change to:

```typescript
const resolved = await resolveTraceOrgProject(parsed, cwd, USAGE_HINT);
traceId = resolved.traceId;
org = resolved.org;

// Resolve numeric project ID when user explicitly provided a project
let projectFilter: string | undefined;
let numericProjectId: number | undefined;
if (parsed.type === "explicit") {
  projectFilter = resolved.project;
  const projectData = resolved.projectData ?? await getProject(org, resolved.project);
  numericProjectId = Number(projectData.id);
}

const spans = await getDetailedTrace(org, traceId, timestamp, additionalAttributes, numericProjectId);
```

Build hint with real values:
```typescript
const summary = computeTraceSummary(traceId, spans);

let hint: string;
if (projectFilter) {
  hint = `Filtered to project '${projectFilter}'. Full trace: sentry trace view ${org}/${traceId}`;
} else if (summary.projects.length > 1) {
  const projectList = summary.projects.join(", ");
  const firstProject = summary.projects[0];
  hint = `This trace spans ${summary.projects.length} projects (${projectList}). Filter: sentry trace view ${org}/${firstProject}/${traceId}`;
} else {
  hint = `Tip: Open in browser with 'sentry trace view --web ${traceId}'`;
}
```

