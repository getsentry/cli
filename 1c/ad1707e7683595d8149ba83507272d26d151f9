### 4. `trace logs` — Pass project in query

**File: `src/commands/trace/logs.ts`**

Capture explicit project from parsed target, prepend `project:{slug}` to query:

```typescript
const parsed = parseTraceTarget(args, USAGE_HINT);
const { traceId, org } = await resolveTraceOrg(parsed, cwd, USAGE_HINT);

// Capture explicit project for API-level filtering
const projectFilter = parsed.type === "explicit" ? parsed.project : undefined;

// Build query with project filter
let query = flags.query;
if (projectFilter) {
  const pf = `project:${projectFilter}`;
  query = query ? `${pf} ${query}` : pf;
}

const logs = await listTraceLogs(org, traceId, {
  ...timeRangeToApiParams(timeRange),
  limit: flags.limit,
  query,
  sort: flags.sort,
});
```

Update usage hint: `"sentry trace logs [<org>/[<project>/]]<trace-id>"`

Update `fullDescription` to document project filtering.

Build hint with real values:
```typescript
if (projectFilter) {
  hint = `Filtered to project '${projectFilter}'. Full trace logs: sentry trace logs ${org}/${traceId}`;
} else {
  hint = `Filter by project: sentry trace logs ${org}/<project>/${traceId}`;
