### 6. Conditional Project column in span table

**File: `src/lib/formatters/trace.ts`**

When `formatSpanTable` receives spans from multiple `project_slug` values, auto-prepend a "Project" column:

```typescript
const PROJECT_COLUMN: Column<FlatSpan> = {
  header: "Project",
  value: (s) => escapeMarkdownCell(s.project_slug || "—"),
  minWidth: 8,
};

export function formatSpanTable(spans: FlatSpan[], extraColumns?: string[]): string {
  const projects = new Set(spans.map(s => s.project_slug).filter(Boolean));
  const base = projects.size > 1 ? [PROJECT_COLUMN, ...SPAN_TABLE_COLUMNS] : SPAN_TABLE_COLUMNS;
  const columns = extraColumns?.length ? [...base, ...buildExtraColumns(extraColumns)] : base;
  return formatTable(spans, columns, { truncate: true });
}
```

### 7. `span list` hints — Add project filter suggestion

**File: `src/commands/span/list.ts`**

In `handleTraceMode`, after fetching spans, add a project filter hint when results span multiple projects:

```typescript
const projects = new Set(flatSpans.map(s => s.project_slug).filter(Boolean));
if (projects.size > 1 && !flags.query?.includes("project:")) {
  const firstProject = [...projects][0];
  const filterHint = `Filter by project: sentry span list ${org}/${firstProject}/${traceId}`;
  hint = hint ? `${hint}\n${filterHint}` : filterHint;
}
```

