**New constant** (after `buildIssueListCollapse`):
```typescript
/**
 * Collapse fields for single-issue detail endpoints.
 *
 * The CLI never displays stats (sparkline), lifetime (aggregate sub-object),
 * filtered (filtered counts), or unhandled (unhandled sub-object) in detail
 * views. Collapsing skips expensive Snuba queries, saving 100-300ms.
 */
export const ISSUE_DETAIL_COLLAPSE: IssueCollapseField[] = [
  "stats", "lifetime", "filtered", "unhandled",
];
```

**Modify `getIssue`** â€” add optional `collapse` param:
```typescript
export function getIssue(
  issueId: string,
  options?: { collapse?: IssueCollapseField[] }
): Promise<SentryIssue> {
  return apiRequest<SentryIssue>(`/issues/${issueId}/`, {
    params: options?.collapse ? { collapse: options.collapse } : undefined,
  });
}
```

**Modify `getIssueInOrg`** â€” switch from SDK `retrieveAnIssue` to `apiRequestToRegion`:
```typescript
export async function getIssueInOrg(
  orgSlug: string,
  issueId: string,
  options?: { collapse?: IssueCollapseField[] }
): Promise<SentryIssue> {
  const regionUrl = await resolveOrgRegion(orgSlug);
  const { data } = await apiRequestToRegion<SentryIssue>(
    regionUrl,
    `/organizations/${orgSlug}/issues/${issueId}/`,
    { params: options?.collapse ? { collapse: options.collapse } : undefined }
  );
  return data;
}
```

**Modify `getIssueByShortId`** â€” switch from SDK `resolveAShortId` to `apiRequestToRegion`:
```typescript
export async function getIssueByShortId(
  orgSlug: string,
  shortId: string,
  options?: { collapse?: IssueCollapseField[] }
): Promise<SentryIssue> {
  const normalizedShortId = shortId.toUpperCase();
  const regionUrl = await resolveOrgRegion(orgSlug);

  let data: { group?: SentryIssue };
  try {
    const result = await apiRequestToRegion<{ group?: SentryIssue }>(
      regionUrl,
      `/organizations/${orgSlug}/shortids/${normalizedShortId}/`,
      { params: options?.collapse ? { collapse: options.collapse } : undefined }
    );
    data = result.data;
  } catch (error) {
    // Preserve existing 404 enrichment logic (same as current)
    if (error instanceof ApiError && error.status === 404) {
      throw new ApiError(
        `Short ID '${normalizedShortId}' not found in organization '${orgSlug}'`,
        404,
        [...existing hints...].join("\n  ")
      );
    }
    throw error;
  }

  if (!data.group) {
    throw new ApiError(
      `Short ID ${normalizedShortId} resolved but no issue group returned`,
      404, "Issue not found"
    );
  }
  return data.group;
}
```

